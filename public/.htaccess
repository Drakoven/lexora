# Renvoie toutes les routes qui ne correspondent pas à un fichier/dossier réel
# vers index.html, pour que React Router gère la navigation côté client
# (nécessaire pour les liens directs comme /verify-email ou /reset-password).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
