# Connexion MySQL (créée via cPanel en prod : "Bases de données MySQL").
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=

# Chaîne aléatoire longue, différente entre dev et prod. Génère-en une nouvelle
# pour la prod (ex. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`).
SESSION_SECRET=

# Port sur lequel Express écoute. En prod, le "Node.js App Selector" de cPanel
# impose généralement son propre port — laisse-le gérer PORT lui-même si c'est
# le cas (il l'injecte automatiquement dans l'environnement de l'app).
PORT=4000

# URL publique du frontend déployé (sert au CORS + à la config du cookie de
# session). Dev : http://localhost:5173. Prod : https://mondomaine.fr (sans
# slash final).
CLIENT_ORIGIN=http://localhost:5173

# "production" active cookie secure + sameSite=none + trust proxy (nécessaires
# derrière le reverse proxy d'un hébergement mutualisé, en HTTPS uniquement).
# Ne PAS mettre en dev (casse les cookies en HTTP local).
NODE_ENV=development

# SMTP pour l'email "mot de passe oublié" (ex. une boîte cPanel créée pour
# l'occasion, ou un service comme Brevo/SendGrid). Si SMTP_HOST est vide, le
# lien de réinitialisation est juste affiché dans les logs du serveur —
# pratique en dev, mais à configurer avant la mise en prod.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Sentry (monitoring d'erreurs). DSN du projet Node.js/Express créé sur
# sentry.io. Si vide, Sentry n'est simplement pas activé (pas requis en dev).
SENTRY_DSN=

# Connexion OAuth Google (console.cloud.google.com > API et services >
# Identifiants > ID client OAuth 2.0, type "Application Web"). URI de
# redirection autorisée à renseigner côté Google : SERVER_ORIGIN +
# "/api/auth/google/callback". Si vide, le bouton "Continuer avec Google"
# redirige simplement vers une erreur — pratique en dev sans app configurée.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Connexion OAuth Facebook (developers.facebook.com > l'app > Produits >
# Connexion Facebook > Paramètres). URI de redirection valide à renseigner
# côté Facebook : SERVER_ORIGIN + "/api/auth/facebook/callback". Même
# comportement que Google si vide.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# URL publique du backend lui-même (nécessaire pour construire l'URL de
# callback OAuth absolue que Google/Facebook redirigent vers en retour).
# Dev : http://localhost:4000. Prod : https://api.mondomaine.fr (sans slash
# final).
SERVER_ORIGIN=http://localhost:4000
