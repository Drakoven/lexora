# URL publique du backend (utilisée par l'API REST et le client Socket.io).
# Dev : laisser vide, ça retombe sur http://localhost:4000 par défaut.
# Prod : URL complète du backend déployé (ex. https://api.mondomaine.fr).
VITE_API_URL=

# Sentry (monitoring d'erreurs). DSN du projet React créé sur sentry.io.
# Si vide, Sentry n'est simplement pas activé (pas requis en dev). Ce n'est
# pas un secret à protéger : il finit de toute façon visible dans le bundle
# JS envoyé au navigateur.
VITE_SENTRY_DSN=
